{
  "name": "experiments",
  "version": "1.0.0",
  "description": "A monorepo of interactive frontend experiments combining ThreeJS, GSAP, Lenis and MotionDev",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "preview": "npm run preview --workspaces --if-present",
    "serve:01": "npm run serve --workspace=packages/experiment-01",
    "serve:02": "npm run serve --workspace=packages/experiment-02",
    "serve:03": "npm run serve --workspace=packages/experiment-03-hinatabokko",
    "serve:04": "npm run serve --workspace=packages/experiment-04-mono-no-aware",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitest": "^3.1.2"
  },
  "keywords": [
    "threejs",
    "gsap",
    "lenis",
    "motion",
    "portfolio",
    "scroll-animation",
    "webgl"
  ],
  "author": "LuXDAmore",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
