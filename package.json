{
  "name": "experiments",
  "version": "1.0.0",
  "description": "A monorepo of interactive frontend experiments combining ThreeJS, GSAP, Lenis and MotionDev",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "preview": "npm run preview --workspaces --if-present",
    "serve:01": "npm run serve --workspace=packages/experiment-01",
    "serve:02": "npm run serve --workspace=packages/experiment-02",
    "serve:03": "npm run serve --workspace=packages/experiment-03-hinatabokko",
    "serve:04": "npm run serve --workspace=packages/experiment-04-mono-no-aware",
    "serve:05": "npm run serve --workspace=packages/experiment-05-komorebi",
    "serve:landing": "npm run serve --workspace=packages/landing"
  },
  "keywords": [
    "threejs",
    "gsap",
    "lenis",
    "motion",
    "portfolio",
    "scroll-animation",
    "webgl"
  ],
  "author": "LuXDAmore",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "dependencies": {
    "@google/design.md": "^0.1.1"
  }
}
